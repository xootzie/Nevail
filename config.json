  "projectHelpURL": "https://github.com/xootzie/Nevail/issues",
  "openInDefaultBrowser": true,
  "openInDefaultBrowserRegex": "https?://(?:www\\.)?discord\\.com/(?!channels(?:/|$)|login(?:\\?|$)|app(?:/|$)|@me(?:/|$)|invite(?:/|$)|store(?:/|$)|library(?:/|$)|activity(?:/|$)|guild-discovery(?:/|$))",
  "runInBackground": true
